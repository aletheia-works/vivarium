# ─── OS ──────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~

# ─── Editors ─────────────────────────────────
.vscode/
.idea/
*.sublime-*
.cursor/

# ─── Environment variables and secrets ───────
.env
.env.local
.env.*.local
*.pem
*.key
!*.pub.key

# ─── OpenTofu / Terraform ────────────────────
# See also per-module .gitignore under infra/*/
# .terraform.lock.hcl is committed for provider version pinning (best practice).
**/.terraform/
**/*.tfstate
**/*.tfstate.*
**/terraform.tfvars
**/terraform.tfvars.json
!**/terraform.tfvars.example
**/*.tfplan
**/crash.log
**/crash.*.log

# ─── Python ──────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/

# ─── Rust ────────────────────────────────────
target/
Cargo.lock
# Library crates ignore Cargo.lock; binary crates commit it.
# Revisit once the concrete project shape is decided.

# ─── JavaScript / TypeScript ─────────────────
node_modules/
dist/
.next/
.nuxt/
.cache/
*.tsbuildinfo
.turbo/
.parcel-cache/

# ─── rspress ─────────────────────────────────
doc_build/
.rspress/

# ─── WASM build artifacts ────────────────────
*.wasm
!**/test/**/*.wasm
*.wat

# ─── Logs / temporary files ──────────────────
*.log
logs/
tmp/
temp/
.tmp/

# ─── Claude Code / AI tools ──────────────────
.claude/
.aider*
.cursor-server/

# ─── Local-only docs (design/strategy memos) ───
/_context/

# ─── Test / coverage ─────────────────────────
coverage/
.coverage
.nyc_output/
htmlcov/

# ─── Misc ────────────────────────────────────
*.bak
*.orig
.scratch/
