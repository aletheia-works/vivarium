# ─── OS ──────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~

# ─── Editors ─────────────────────────────────
.vscode/
.idea/
*.sublime-*
.cursor/

# ─── Environment variables and secrets ───────
.env
.env.local
.env.*.local
*.pem
*.key
!*.pub.key

# ─── OpenTofu / Terraform ────────────────────
# See also per-module .gitignore under infra/*/
# .terraform.lock.hcl is committed for provider version pinning (best practice).
**/.terraform/
**/*.tfstate
**/*.tfstate.*
**/terraform.tfvars
**/terraform.tfvars.json
!**/terraform.tfvars.example
**/*.tfplan
**/crash.log
**/crash.*.log

# ─── Python ──────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/

# ─── Rust ────────────────────────────────────
target/
Cargo.lock
# Library crates ignore Cargo.lock; binary crates commit it.
# Revisit once the concrete project shape is decided.

# ─── JavaScript / TypeScript ─────────────────
node_modules/
dist/
.next/
.nuxt/
.cache/
*.tsbuildinfo
.turbo/
.parcel-cache/

# Layer 1 sources are .ts; tsc emits .js / .js.map alongside the source.
# Only the .ts source belongs in version control.
src/layer1_wasm/**/*.js
src/layer1_wasm/**/*.js.map
src/layer1_wasm/**/*.d.ts
src/layer1_wasm/**/*.d.ts.map
# `repro.highlighted.html` is generated by scripts/highlight-repros.ts
# (Shiki, ADR-0028 §V′). Recipe pages fetch it at runtime to upgrade
# from plain-text to syntax-highlighted source. Same gitignore policy
# as the .js outputs: only the source TS belongs in version control.
src/layer1_wasm/**/repro.highlighted.html
# `playwright.config.ts` IS tracked — `*.ts` is fine, only generated
# `*.js` next to it would be excluded.
# Hand-written shared assets (`chrome.js`, `sw.js`) live in `_assets/`
# rather than `_shared/` so the broad `*.js` ignore above doesn't apply
# to them — `_shared/` is exclusively for TS sources + their tsc-emitted
# `.js` siblings. Force-include the whole `_assets/` tree.
!src/layer1_wasm/_assets/
!src/layer1_wasm/_assets/**

# Playwright run artefacts (test reports, traces, screenshots).
src/layer1_wasm/playwright-report/
src/layer1_wasm/test-results/
src/layer1_wasm/blob-report/
src/layer1_wasm/.last-run.json
# Same artefacts for the docs-site E2E suite (`docs/playwright.config.ts`,
# added in PR #189). Generated under docs/ on every `bun run test:e2e`
# run; CI uploads playwright-report/ as a workflow artifact on failure
# but neither directory is meant to live in version control.
docs/playwright-report/
docs/test-results/
docs/blob-report/
docs/.last-run.json

# ─── rspress ─────────────────────────────────
doc_build/
.rspress/

# ajv-standalone validators emitted by `docs/scripts/generate-validators.ts`
# from the schemas under `docs/public/spec/`. Reproducible from the schema
# + the codegen script + pinned ajv/ajv-formats versions; the schemas are
# the source of truth. See ADR-0034 for the migration rationale.
docs/generated/

# Per-project landing pages under `/repro/<project>/` are generated at
# build time by `docs/scripts/generate-project-pages.ts` from the
# `docs/public/api/projects.json` index — see the AUTO-GENERATED marker
# inside each emitted MDX. Regenerated on every `bun run dev` / `build`,
# so checking them in would just create noise.
docs/docs/*/repro/*/index.mdx

# ─── WASM build artifacts ────────────────────
*.wasm
!**/test/**/*.wasm
*.wat

# ─── Layer 2 (Docker) build artefacts ────────
# `verdict.json` is generated by `deploy-docs.yml` on each push to
# main and shipped to GitHub Pages alongside the page. Tracking it
# in the repo would make every CI build a noisy commit; the gallery
# reads the deployed copy instead.
src/layer2_docker/**/verdict.json

# ─── Layer 3 (rr record-replay) build artefacts ────
# `record.sh` writes the captured trace to `<recipe>/out/<name>.tar.zst`
# before the maintainer uploads it as a Release asset; the Release
# asset is the canonical artefact, the local copy is scratch.
# Note: `<recipe>/verdict.json` is INTENTIONALLY tracked for Layer 3
# (CI cannot regenerate it — see `src/layer3_thirdway/README.md` and
# ADR-0011) — there is no per-recipe verdict.json ignore line here.
src/layer3_thirdway/**/out/

# ─── Logs / temporary files ──────────────────
*.log
logs/
tmp/
temp/
.tmp/

# ─── Claude Code / AI tools ──────────────────
.claude/
.aider*
.cursor-server/

# ─── Local-only docs (design/strategy memos) ───
/_context/

# ─── Test / coverage ─────────────────────────
coverage/
.coverage
.nyc_output/
htmlcov/

# ─── Misc ────────────────────────────────────
*.bak
*.orig
.scratch/
