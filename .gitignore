# ─── OS ──────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~

# ─── Editors ─────────────────────────────────
.vscode/
.idea/
*.sublime-*
.cursor/

# ─── Environment variables and secrets ───────
.env
.env.local
.env.*.local
*.pem
*.key
!*.pub.key

# ─── OpenTofu / Terraform ────────────────────
**/.terraform/
**/*.tfstate
**/*.tfstate.*
**/terraform.tfvars
**/terraform.tfvars.json
!**/terraform.tfvars.example
**/*.tfplan
**/crash.log
**/crash.*.log

# ─── Python ──────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/

# ─── Rust ────────────────────────────────────
target/
# Cargo.lock ignored — current crates are libraries; revisit when a
# binary crate is added.
Cargo.lock

# ─── JavaScript / TypeScript ─────────────────
node_modules/
dist/
.next/
.nuxt/
.cache/
*.tsbuildinfo
.turbo/
.parcel-cache/

# Layer 1 sources are .ts; tsc emits .js / .js.map alongside the source.
# Only the .ts source belongs in version control.
src/layer1_wasm/**/*.js
src/layer1_wasm/**/*.js.map
src/layer1_wasm/**/*.d.ts
src/layer1_wasm/**/*.d.ts.map
# Generated by scripts/highlight-repros.ts (Shiki, ADR-0028).
src/layer1_wasm/**/repro.highlighted.html
# `_assets/` holds hand-written `*.js` (chrome.js, sw.js); force-include
# so the broad `*.js` rule above does not catch them.
!src/layer1_wasm/_assets/
!src/layer1_wasm/_assets/**

# Layer 1 fix-candidate wheels (ADR-0040): the wheel binary and its
# generated `manifest.json` are built by `mise run repro:build:wheels`
# (locally) or by `deploy-docs.yml` (CI) from each
# `<slug>/wheels/source.json`. Only `source.json` is tracked.
src/layer1_wasm/**/wheels/*.whl
src/layer1_wasm/**/wheels/manifest.json

# Playwright run artefacts (reports, traces, screenshots).
src/layer1_wasm/playwright-report/
src/layer1_wasm/test-results/
src/layer1_wasm/blob-report/
src/layer1_wasm/.last-run.json
docs/playwright-report/
docs/test-results/
docs/blob-report/
docs/.last-run.json

# ─── rspress ─────────────────────────────────
doc_build/
.rspress/

# Generated by docs/scripts/generate-validators.ts (ADR-0034).
docs/generated/

# Generated by docs/scripts/generate-project-pages.ts on every build.
docs/docs/*/repro/*/index.mdx

# Generated by `bun run sync:bundled` in packages/mcp-server (chained
# into `build` and `test`). Canonical source is
# docs/public/api/recipes.json; this is the offline-fallback snapshot
# that ships in the npm/JSR tarball, regenerated at every publish so
# it never drifts.
packages/mcp-server/src/bundled/recipes.json

# ─── WASM build artifacts ────────────────────
*.wasm
!**/test/**/*.wasm
*.wat

# ─── Layer 2 (Docker) build artefacts ────────
# verdict.json is CI-generated and shipped to Pages, not tracked.
src/layer2_docker/**/verdict.json

# ─── Layer 3 (rr record-replay) build artefacts ────
# Trace tarballs are scratch; the Release asset is the canonical artefact.
# Layer 3 verdict.json is INTENTIONALLY tracked (CI cannot regenerate;
# see src/layer3_thirdway/README.md and ADR-0011) — no ignore line for it.
src/layer3_thirdway/**/out/

# ─── Logs / temporary files ──────────────────
*.log
logs/
tmp/
temp/
.tmp/

# ─── Claude Code / AI tools ──────────────────
# `.claude/` is tracked; only `*.local.*` files stay personal.
.claude/CLAUDE.local.md
.claude/settings.local.json
.aider*
.cursor-server/

# ─── Local-only docs (design/strategy memos) ───
/_context/

# ─── Test / coverage ─────────────────────────
coverage/
.coverage
.nyc_output/
htmlcov/

# ─── Misc ────────────────────────────────────
*.bak
*.orig
.scratch/
